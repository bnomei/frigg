        "PACKAGES.md",
        "README.md",
        "vim.yml",
        "doc/mason.txt",
        ".github/workflows/cbfmt.yml"
      ],
      "expected_kinds": [
        "entrypoints",
        "runtime-config"
      ]
    },
    {
