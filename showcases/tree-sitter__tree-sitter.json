    {
      "case_id": "web-binding-and-wasm-tooling-flow",
      "question": "Which files define tree-sitter's web binding and WASM tooling flow?",
      "expected_answer_shape": "ranked_paths_or_source_backed_summary",
      "expected_paths_any": [
        "lib/binding_web/src/bindings.ts",
