        "routes/console.php",
        "routes/middleware.php",
        "routes/web.php"
      ],
      "expected_paths_should": [
        "bootstrap/app.php",
        "bootstrap/providers.php",
        "config/app.php",
        "config/auth.php",
        "config/broadcasting.php",
        "config/cache.php"
      ],
      "expected_kinds": [
        "routes",
        "providers"
      ]
    },
    {
      "case_id": "view-scaffold-and-config",
      "question": "Which files define cachet's view scaffold and config?",
      "expected_answer_shape": "ranked_paths_or_source_backed_summary",
